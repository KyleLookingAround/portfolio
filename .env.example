# Stockport Dashboard - Environment Variables Example
# Copy this file to .env and add your API keys

# Optional: Transport for Greater Manchester API
# Get your free API key at: https://developer.tfgm.com/
# VITE_TFGM_API_KEY=your_tfgm_api_key_here

# Optional: NHS API
# Get your free API key at: https://digital.nhs.uk/developer
# VITE_NHS_API_KEY=your_nhs_api_key_here

# Optional: Eventbrite API
# Get your token at: https://www.eventbrite.com/platform/api
# VITE_EVENTBRITE_TOKEN=your_eventbrite_token_here

# Note: API keys prefixed with VITE_ are exposed to the browser
# The dashboard will work without these keys, using fallback data
